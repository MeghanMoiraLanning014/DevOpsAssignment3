pipeline {
    agent any

    environment {
        APP_REPO_URL   = 'https://github.com/MeghanMoiraLanning014/colorpalette.git'
        TEST_REPO_URL  = 'https://github.com/MeghanMoiraLanning014/ColorPalette-Tests.git'
    }

    stages {
        stage('Checkout App Code') {
            steps {
                git branch: 'main', url: "${APP_REPO_URL}"
            }
        }

        stage('Prepare Environment') {
            steps {
                sh '''
                echo "MONGODB_URI=mongodb://db:27017/colorpalette" > .env
                echo "COOKIE_DOMAIN=localhost" >> .env
                echo "NODE_ENV=production" >> .env
                echo "JWT_SECRET=45e269616244b956ae28e61bd633899d" >> .env
                '''
            }
        }

        stage('Clean Previous Containers') {
            steps {
                sh 'docker compose -f docker-compose.ci.yml down || true'
            }
        }

        stage('Build & Deploy') {
            steps {
                // Increased timeout for dependency installation and build
                sh 'docker compose -p colorpalette -f docker-compose.ci.yml up -d'
                echo 'Waiting for application to build and start...'
                sh 'sleep 60' 
            }
        }

        stage('Run Tests') {
            steps {
                sh 'rm -rf test-repo && git clone ${TEST_REPO_URL} test-repo'
                sh '''
                docker run --rm \
                    --network host \
                    -v $(pwd)/test-repo:/usr/src/app \
                    -w /usr/src/app \
                    markhobson/maven-chrome:jdk-11 \
                    mvn test -Dapp.url=http://localhost:5001
                '''
            }
        }
    }

    post {
        always {
            junit allowEmptyResults: true,
                  testResults: 'test-repo/target/surefire-reports/*.xml'
        }
        success {
            echo 'Pipeline passed successfully!'
        }
        failure {
            echo 'Pipeline failed. Check the logs for npm install or build errors.'
        }
    }
}
